# TSADAI configuration template.
# Copy this file to `.env`, then edit the values for your machine.

# ---------------------------------------------------------------------------
# Network size and local ports
# ---------------------------------------------------------------------------
NUM_NODES=8
BASE_PORT=8002
API_BASE_PORT=9002
API_HOST=127.0.0.1

# Address mode choices:
# - ipv6_loopback: local development only, advertises /ip6/::1 addresses.
ADVERTISE_ADDRESS_MODE=ipv6_loopback

# ---------------------------------------------------------------------------
# Backend choices
# ---------------------------------------------------------------------------
# Choose one backend for answering requests and classification.
# - ollama: use a local Ollama server.
# - aiass: use the EPFL AIaaS OpenAI-compatible API.
# - local: use a local Hugging Face model through transformers.
# - dummy: no real model, returns placeholder answers.
REQUEST_BACKEND=ollama
CLASSIFIER_BACKEND=ollama

# ---------------------------------------------------------------------------
# Local Hugging Face backend, used when a backend choice is local
# ---------------------------------------------------------------------------
LOCAL_MODEL_ID=Qwen/Qwen3-1.7B
# Can be the same as LOCAL_MODEL_ID, or a smaller/faster local model.
LOCAL_CLASSIFIER_MODEL_ID=Qwen/Qwen3-1.7B
# Usable local Transformers model examples:
# - Qwen/Qwen3-1.7B
# - Qwen/Qwen3-4B
# - Qwen/Qwen3-8B
LOCAL_MAX_NEW_TOKENS=512

# Choices: true or false.
LOCAL_ENABLE_THINKING=false
LOCAL_TIMEOUT=60

# ---------------------------------------------------------------------------
# Ollama backend, used when a backend choice is ollama
# ---------------------------------------------------------------------------
OLLAMA_MODEL=qwen3:1.7b
# Can be the same as OLLAMA_MODEL, or a smaller/faster Ollama model.
OLLAMA_CLASSIFIER_MODEL=qwen3:1.7b
# Usable Ollama model examples:
# - qwen3:1.7b
# - qwen3:4b
# - qwen3:8b
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=60
OLLAMA_CHECK_TIMEOUT=5
OLLAMA_NUM_PREDICT=512

# ---------------------------------------------------------------------------
# EPFL AIaaS backend, used when a backend choice is aiass
# ---------------------------------------------------------------------------
# Required only when REQUEST_BACKEND or CLASSIFIER_BACKEND is aiass.
AIASS_API_KEY=YOUR_AIASS_API_KEY_HERE

AIASS_BASE_URL=https://inference-rcp.epfl.ch/v1

# Pick models your AIaaS key is allowed to access.
# AIASS_CLASSIFIER_MODEL can be smaller/faster than AIASS_MODEL.
# Usable AIaaS model examples:
# - swiss-ai/Apertus-8B-Instruct-2509
# - mistralai/Mistral-Small-3.2-24B-Instruct-2506
# - Qwen/Qwen3-30B-A3B-Instruct-2507
AIASS_MODEL=swiss-ai/Apertus-8B-Instruct-2509
AIASS_CLASSIFIER_MODEL=swiss-ai/Apertus-8B-Instruct-2509

AIASS_TIMEOUT=60
AIASS_MAX_TOKENS=512

# ---------------------------------------------------------------------------
# Routing and user-facing timeouts
# ---------------------------------------------------------------------------
# These values keep the UI/client wait below CLIENT_QUERY_TIMEOUT.
CLASSIFIER_TIMEOUT=60
QUERY_TIMEOUT=60
QUERY_CONNECT_TIMEOUT=2
CLIENT_QUERY_TIMEOUT=300
PING_TIMEOUT=5

# ---------------------------------------------------------------------------
# Web UI
# ---------------------------------------------------------------------------
WEB_HOST=127.0.0.1
WEB_PORT=8000
# Approximate amount of chat history sent to the next node for continuity.
# Long conversations are kept locally, but only recent turns fit in context.
WEB_CONTEXT_TOKENS=2000
WEB_CONTEXT_CHARS_PER_TOKEN=4
